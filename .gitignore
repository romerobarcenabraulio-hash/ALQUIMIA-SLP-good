__pycache__/
*.pyc
*.pyo
.DS_Store
**/.DS_Store

# Node — nunca subir dependencias (Vercel hace npm install en build)
node_modules/
frontend/node_modules/

# Python entornos locales
.venv/
backend/.venv/
venv/

# Lighthouse / auditoría local (mantener solo .gitkeep)
frontend/audit_reports/*
!frontend/audit_reports/.gitkeep

# Secretos / env local (ACCESS_CODE, tokens)
frontend/.env.local
frontend/.env.*.local
backend/.env
backend/.env.save
backend/.env.*.local

# Temporales de Office / editores
~$*

# Config local Claude / IDE
**/.claude/settings.local.json

# Build output — NO commitear artefactos de build (causan fallos cross-platform en Vercel)
frontend/.next/
frontend/out/
frontend/.turbo/

# TypeScript incremental (local; cambia en cada tsc y ensucia diffs/PRs)
frontend/tsconfig.tsbuildinfo
