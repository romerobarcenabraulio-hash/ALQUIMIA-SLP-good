# ─── ALQUIMIA API · variables de entorno ─────────────────────────────────────
# Copiar a `.env` en local. En Railway/Render: definir las mismas claves en el panel.
#
# ■ Arranque mínimo (API + /health sin DB externa)
#   - Ninguna variable es estrictamente obligatoria para que el proceso levante:
#     la app usa defaults en `app/config.py` (SECRET_KEY y DATABASE_URL de desarrollo).
#   - En producción debes fijar al menos SECRET_KEY y, si usas auth/DB real, DATABASE_URL.
#
# ■ Obligatorias recomendadas en PRODUCCIÓN
#   SECRET_KEY          — Firma JWT en /auth; usar valor largo aleatorio (obligatorio si expones login).
#   ENVIRONMENT         — production | staging | development (aparece en /health).
#
# ■ Base de datos (si rutas persisten o usan SQL)
#   DATABASE_URL        — PostgreSQL (Railway Postgres, Supabase, etc.). Sin esto, el default apunta a localhost.
#
# ■ CORS (frontend Vercel u otros dominios)
#   ALLOWED_ORIGINS     — Orígenes extra separados por coma, sin espacios accidentales.
#                         Ya están incluidos por código: localhost:3000, alquimia.mx, alquimia-slp.vercel.app
#
# ■ Puerto (Railway/Render)
#   PORT                — El Dockerfile respeta PORT; Railway lo inyecta automáticamente.
#
# ■ Opcionales (funcionalidades / integraciones)
#   SERPER_API_KEY, MAPBOX_TOKEN, ANTHROPIC_API_KEY, GOOGLE_SERVICE_ACCOUNT_FILE, etc.

SECRET_KEY=
DATABASE_URL=
ALLOWED_ORIGINS=
ENVIRONMENT=production
LOG_LEVEL=info
PORT=8000

# ─── Integración ───────────────────────────────────────────────────────────────
# INEGI APIs (DENUE Banco de indicadores, según tu registro en inegi.org.mx):
INEGI_API_TOKEN=
# Opcional — mismos alcances si INEGI te entregó un token solo para DENUE:
# INEGI_DENUE_TOKEN=
# DENUE_API_TOKEN=

# ANTHROPIC_API_KEY=

# ── Frontend access gate (R3) ────────────────────────────────────────────────
# Código de acceso para el password-gate de /simulator, /hub, /ca-studio.
# Se lee como ACCESS_CODE (sin NEXT_PUBLIC_) en el Route Handler /api/acceso.
# Nunca expongas este valor al cliente.
# ACCESS_CODE=
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
