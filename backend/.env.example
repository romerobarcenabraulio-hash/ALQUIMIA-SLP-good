# ─── ALQUIMIA API · variables de entorno ─────────────────────────────────────
# Copiar a backend/.env — ver cursor-rules/AGENT_API_KEYS.md para prioridades.

# ■ Producción (mínimo)
SECRET_KEY=
ENVIRONMENT=development
DATABASE_URL=postgresql://alquimia:alquimia@localhost:5432/alquimia

# ■ CORS frontend
ALLOWED_ORIGINS=http://localhost:3000
APP_PUBLIC_URL=http://localhost:3000
PORT=8000
LOG_LEVEL=info

# ■ Cuentas institucionales (registro + TOTP)
REGISTRATION_ENABLED=true
EMAIL_PROVIDER=console
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=
# EMAIL_FROM=ALQUIMIA <noreply@alquimia.mx>

# ■ SMS — verificación teléfono + segundo factor en login
SMS_PROVIDER=console
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=+52XXXXXXXXXX

# ─── Agentes y research (orden recomendado de activación) ────────────────────

# 1. PostgreSQL (arriba) + alembic upgrade head

# 2. ÁGORA — documentos (consume tokens; usar tras caché research)
ANTHROPIC_API_KEY=
# Rápido: claude-haiku-4-5-20251001 | Calidad: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
INVESTIGADOR_ENABLED=true

# 3. Serper — investigación web (omitido si hay caché DB < 6h)
SERPER_API_KEY=

# 4. Perplexity — DIFERIDO (no configurar sin presupuesto)
# PERPLEXITY_API_KEY=

# ─── Datos públicos (opcional, sin tokens LLM) ───────────────────────────────
INEGI_API_TOKEN=
# API de Ruteo SAKBÉ (36 chars) — https://gaia.inegi.org.mx/sakbe_v3.1/genera_token.jsp
INEGI_RUTEO_TOKEN=
BANXICO_TOKEN=

# ─── Mapas / Places (Render — nombres del dashboard) ─────────────────────────
GOOGLE_PLACES_API_KEY=
GEOCODING_API=
OPTIMIZATION_ROUTE_API=
MAPS_PLATFORM_API=
PLACES_SYNC_ENABLED=true

# ─── Cron (HERMES 19:00, KRONOS semanal) ─────────────────────────────────────
# Render Cron Job → POST /api/v1/cron/logistics-daily-summary con header X-Cron-Secret
CRON_SECRET=

# ─── Google Drive export (opcional) ──────────────────────────────────────────
GOOGLE_SERVICE_ACCOUNT_FILE=
