# ── API backend ──────────────────────────────────────────────────────────────
# URL del API FastAPI (sin barra final). En Vercel: producción/staging del backend (Railway/Render).
# Ejemplo tras deploy: https://tu-servicio.up.railway.app
# Sin esta variable en build, el cliente usa http://localhost:8000 (solo desarrollo local).
NEXT_PUBLIC_API_URL=

# URL pública del frontend (backend la usa en enlaces de verificación de correo)
# En Vercel: https://tu-dominio.vercel.app
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_APP_ENV=production

# ── Google Maps (Vercel) ─────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Deprecated — usar Google Maps arriba
# NEXT_PUBLIC_MAPBOX_TOKEN=

# ── Access gate R3 (middleware + cookie httpOnly) — LEGACY ───────────────────
# DEPRECADO en landing (mayo 2026): el login inline usa POST /api/auth/login + demo-token.
# ACCESS_CODE y POST /api/acceso siguen disponibles para middleware legacy (/simulator gate cookie).
#
# CÓMO FUNCIONA (legacy)
#   POST /api/acceso compara body.code con ACCESS_CODE y fija cookie httpOnly `alquimia_access`.
#   middleware.ts lee esa cookie para rutas protegidas históricas.
#
# FLUJO CANÓNICO CLIENTE (2026-05):
#   / → login inline → /api/auth/login → localStorage alquimia_token → /gobierno o /simulator
#
ACCESS_CODE=

# ── Capa social / demografía (simulador · PR3–PR5) ────────────────────────────
# Origen del bundle de indicadores sociodemográficos (solo lectura).
#   static (default si vacío o distinto de "remote"): usa `public/data/social-stats/slices-<buildId>.json`
#     coherente con `SOCIAL_STATS_BUILD_ID` en código (`frontend/src/data/socialStats/embeddedBundle.ts`).
#   remote: GET al JSON indicado en NEXT_PUBLIC_SOCIAL_STATS_REMOTE_URL (https obligatorio en prod).
NEXT_PUBLIC_SOCIAL_STATS_SOURCE=
# URL absoluta del bundle JSON (misma forma SocialStatsBundle: buildId + slices[]).
# Obligatoria si NEXT_PUBLIC_SOCIAL_STATS_SOURCE=remote; ignorada en modo static.
NEXT_PUBLIC_SOCIAL_STATS_REMOTE_URL=

# Oculta preview/export Markdown PR5 (copiar / descargar) y panel handoff asociado en UI.
# Valores que ocultan: 1 | true | yes (case-insensitive).
NEXT_PUBLIC_SOCIAL_CONTEXT_EXPORT_HIDDEN=

# Audiencia ciudadana: fuerza simplificación de superficie; también oculta export PR5 si true.
# Valores: 1 | true | yes (case-insensitive). Ver `frontend/src/lib/social/pr5ExportConstants.ts`.
NEXT_PUBLIC_CITIZEN_UI=

# QA only: duplica el disclaimer en bloque mono además del panel estándar (no usar en prod institucional).
NEXT_PUBLIC_SHOW_SOCIAL_AUDIT_PLACEHOLDER=

# Trazabilidad humana Excel ↔ slices: `frontend/src/data/socialStats/SOURCE_TRACE.md` y `fuentes de calculo/`.
# Smoke manual: `cursor-rules/SMOKE_SOCIAL_LAYER.md`.
