{
  "$schema": "alquimia/config/cron.v1",
  "updated": "2026-05-26",
  "owner": "HERMES+KRONOS+GEO",
  "jobs": {
    "geo_denue_nacional_sync": {
      "schedule_utc": "0 10 * * *",
      "schedule_local_mx": "04:00 America/Mexico_City",
      "endpoint": "POST /api/v1/cron/geo-denue-nacional-sync",
      "description": "GeoNacionalWorker — ~50 CVE/día DENUE + candidatos operador"
    },
    "geo_places_estado_rotation": {
      "schedule_utc": "0 11 * * *",
      "schedule_local_mx": "05:00 America/Mexico_City",
      "endpoint": "POST /api/v1/cron/geo-places-estado-rotation",
      "description": "Google Places+DENUE+operador candidato — 1 entidad/día (config/geo_nacional_estados.json)"
    },
    "geo_depot_report_weekly": {
      "schedule_utc": "0 12 * * 0",
      "schedule_local_mx": "06:00 domingo America/Mexico_City",
      "endpoint": "POST /api/v1/cron/geo-depot-report",
      "description": "Regenera data/geo/depot_por_municipio.json (almacén concesionario por CVE)"
    },
    "logistics_daily_summary": {
      "schedule_utc": "0 19 * * *",
      "schedule_local_mx": "13:00 America/Mexico_City",
      "endpoint": "POST /api/v1/cron/logistics-daily-summary",
      "description": "HERMES multi-ZM daily_summary → AURUM AC → KRONOS"
    },
    "weekly_status": {
      "schedule_utc": "0 14 * * 1",
      "endpoint": "POST /api/v1/cron/weekly-status",
      "description": "KRONOS genera weekly_status semanal"
    }
  },
  "render_cron_hint": "Crear Cron Job en Render apuntando al endpoint con header X-Cron-Secret"
}
